# ========================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ========================================
DB_SERVER=localhost,1433
DB_NAME=aspnet_learning_platform
DB_USER=sa
DB_PASSWORD=P@ssw0rd!2026#SecurePlatform

# ========================================
# RABBITMQ - MESSAGE BROKER
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=SimplePass123

# ========================================
# JWT - AUTENTICAÇÃO
# ========================================
# IMPORTANTE: Gere uma chave segura para produção
# Exemplo: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ISSUER=AspNetLearningPlatform
JWT_AUDIENCE=AspNetLearningPlatform
JWT_EXPIRATION_MINUTES=60

# ========================================
# FRONTEND - NEXT.JS
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:5000

# ========================================
# OBSERVABILIDADE
# ========================================
# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ========================================
# SERVIÇOS - PORTAS
# ========================================
# API Gateway
GATEWAY_PORT=5000

# Auth Service
AUTH_SERVICE_PORT=5001

# Course Service
COURSE_SERVICE_PORT=5002

# Progress Service
PROGRESS_SERVICE_PORT=5003

# Gamification Service
GAMIFICATION_SERVICE_PORT=5004

# Notification Service
NOTIFICATION_SERVICE_PORT=5005

# Execution Service
EXECUTION_SERVICE_PORT=5006

# Analytics Service
ANALYTICS_SERVICE_PORT=5007

# ========================================
# AMBIENTE
# ========================================
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# ========================================
# LOGS
# ========================================
LOG_LEVEL=Information
SERILOG_MINIMUM_LEVEL=Information
