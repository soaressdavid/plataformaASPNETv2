{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=aspnet_learning_platform;User Id=sa;Password=P@ssw0rd!2026#SecurePlatform;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "AspNetLearningPlatform",
    "Audience": "AspNetLearningPlatform",
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!2024"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },
      "content-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/v1/content/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/content/{**catch-all}"
          }
        ]
      },
      "execute-route": {
        "ClusterId": "execution-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/execute/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/execute/{**catch-all}"
          }
        ]
      },
      "sql-route": {
        "ClusterId": "sql-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/sql/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/sql/{**catch-all}"
          }
        ]
      },
      "gamification-route": {
        "ClusterId": "gamification-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/gamification/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/gamification/{**catch-all}"
          }
        ]
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/ai/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/ai/{**catch-all}"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/notifications/{**catch-all}"
          }
        ]
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/analytics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/analytics/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "content-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "execution-cluster": {
        "Destinations": {
          "destination1": {
