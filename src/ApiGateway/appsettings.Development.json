{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "courses-route": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "progress-route": {
        "ClusterId": "progress-cluster",
        "Match": {
          "Path": "/api/progress/{**catch-all}"
        }
      },
      "challenges-route": {
        "ClusterId": "challenge-cluster",
        "Match": {
          "Path": "/api/challenges/{**catch-all}"
        }
      },
      "ai-tutor-route": {
        "ClusterId": "ai-tutor-cluster",
        "Match": {
          "Path": "/api/ai-tutor/{**catch-all}"
        }
      },
      "execution-route": {
        "ClusterId": "execution-cluster",
        "Match": {
          "Path": "/api/code/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        }
      },
      "sql-executor-route": {
        "ClusterId": "sql-executor-cluster",
        "Match": {
          "Path": "/api/sql/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "course-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "progress-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "challenge-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "ai-tutor-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "execution-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5009"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5010"
          }
        }
      },
      "sql-executor-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5008"
          }
        }
      }
    }
  }
}
