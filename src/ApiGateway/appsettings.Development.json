{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Yarp": "Information",
        "System": "Warning"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "courses-route": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "challenges-route": {
        "ClusterId": "challenge-cluster",
        "Match": {
          "Path": "/api/challenges/{**catch-all}"
        }
      },
      "progress-route": {
        "ClusterId": "progress-cluster",
        "Match": {
          "Path": "/api/progress/{**catch-all}"
        }
      },
      "leaderboard-route": {
        "ClusterId": "progress-cluster",
        "Match": {
          "Path": "/api/leaderboard/{**catch-all}"
        }
      },
      "code-execute-route": {
        "ClusterId": "execution-cluster",
        "Match": {
          "Path": "/api/code/execute/{**catch-all}"
        }
      },
      "code-status-route": {
        "ClusterId": "execution-cluster",
        "Match": {
          "Path": "/api/code/status/{**catch-all}"
        }
      },
      "code-review-route": {
        "ClusterId": "ai-tutor-cluster",
        "Match": {
          "Path": "/api/code/review/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "course-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "challenge-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "progress-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "ai-tutor-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "execution-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      }
    }
  }
}
