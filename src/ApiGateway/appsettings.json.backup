{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Warning",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{ServiceName}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/ApiGateway-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "Application": "ASP.NET Learning Platform",
      "ServiceName": "ApiGateway"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=aspnet_learning_platform;User Id=sa;Password=${DB_PASSWORD};TrustServerCertificate=True",
    "Redis": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "platform_user",
    "Password": "${RABBITMQ_PASSWORD}"
  },
  "Jwt": {
    "PublicKeyPem": null
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "CircuitBreaker": {
    "FailureThreshold": 5,
    "DurationOfBreakInSeconds": 30
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "levels-route": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/api/levels/{**catch-all}"
        }
      },
      "courses-route": {
        "ClusterId": "course-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "challenges-route": {
        "ClusterId": "challenge-cluster",
        "Match": {
          "Path": "/api/challenges/{**catch-all}"
        }
      },
      "progress-route": {
        "ClusterId": "progress-cluster",
        "Match": {
          "Path": "/api/progress/{**catch-all}"
        }
      },
      "leaderboard-route": {
        "ClusterId": "progress-cluster",
        "Match": {
          "Path": "/api/leaderboard/{**catch-all}"
        }
      },
      "code-execute-route": {
        "ClusterId": "execution-cluster",
        "Match": {
          "Path": "/api/code/execute/{**catch-all}"
        }
      },
      "code-status-route": {
        "ClusterId": "execution-cluster",
        "Match": {
          "Path": "/api/code/status/{**catch-all}"
        }
      },
      "code-review-route": {
        "ClusterId": "ai-tutor-cluster",
        "Match": {
          "Path": "/api/code/review/{**catch-all}"
        }
      },
      "projects-route": {
        "ClusterId": "project-cluster",
        "Match": {
          "Path": "/api/projects/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "course-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "challenge-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "progress-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "ai-tutor-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "execution-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "project-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5007"
          }
        }
      }
    }
  }
}
