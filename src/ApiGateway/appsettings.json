{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "courses-route": {
        "ClusterId": "courses-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "challenges-route": {
        "ClusterId": "challenges-cluster",
        "Match": {
          "Path": "/api/challenges/{**catch-all}"
        }
      },
      "progress-route": {
        "ClusterId": "progress-cluster",
        "Match": {
          "Path": "/api/progress/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "courses-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        },
        "HttpRequest": {
          "Timeout": "00:02:00"
        }
      },
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        },
        "HttpRequest": {
          "Timeout": "00:02:00"
        }
      },
      "challenges-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        },
        "HttpRequest": {
          "Timeout": "00:02:00"
        }
      },
      "progress-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        },
        "HttpRequest": {
          "Timeout": "00:02:00"
        }
      }
    }
  }
}
