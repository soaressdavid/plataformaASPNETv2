## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Node modules
node_modules/
frontend/.next/
frontend/out/
frontend/coverage/

# Environment variables
.env
.env.local
!.env.example
!frontend/.env.local.example

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Process IDs
.pids

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Test scripts (opcional - remova se quiser commitar)
test-aspnet-execution.ps1
restart-execution.ps1

# Documentos temporários de desenvolvimento (opcional)
ANALISE_*.md
ARQUIVOS_PARA_REMOVER.md
CORRECOES_*.md
PROBLEMA_*.md
RESUMO_*.md
STATUS_*.md
IMPLEMENTACAO_*.md
EXECUCAO_*.md

# No Docker Config
appsettings.NoDocker.json
*.db
*.db-shm
*.db-wal
